# Servidor
PORT=4000
NODE_ENV=production

# URLs
PUBLIC_APP_URL=https://esinsa-sga-app.up.railway.app
FRONTEND_URL=https://senseikatana.com

# ============================================================
# JARVIS AI — Cerebro LLM
#
# PRINCIPAL: Google Gemini (AI Studio) — GRATIS, sin tarjeta.
#   1. Entra en https://aistudio.google.com/apikey
#   2. "Create API key" → cópiala aquí
#   Cadena anti-consumo: si el modelo principal agota cuota,
#   JARVIS cambia automáticamente al fallback (límites más altos).
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite

# FALLBACK 2: OpenRouter — gratis en https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# ============================================================
# WhatsApp Business Cloud API (Meta) — JARVIS 24/7
# Configuración en https://developers.facebook.com/apps
# 1. Crea una app → añade el producto "WhatsApp"
# 2. WHATSAPP_TOKEN: token permanente (System User)
# 3. WHATSAPP_PHONE_NUMBER_ID: ID del número de prueba/producción
# 4. WHATSAPP_VERIFY_TOKEN: cadena que tú eliges para el webhook
# 5. Webhook URL en Meta: https://esinsa-sga-app.up.railway.app/api/whatsapp/webhook
# ============================================================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=esinsa_jarvis_verify
# Opcional: limita qué números puede atender JARVIS (separados por coma)
WHATSAPP_RECIPIENT_WHITELIST=

# ============================================================
# Google Sheets (sincronización Excel/Sheet)
# ============================================================
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# JARVIS Configuration
JARVIS_ENABLED=true
JARVIS_REALTIME_SYNC=true
JARVIS_LOW_STOCK_THRESHOLD=100
