---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../data/esinsa-content.json';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://esinsa-sga-app.up.railway.app';

const company = content.site.company;
const empresa = content.pages.empresa;
const home = content.pages.home;
---

<BaseLayout title="ESINSA Gaskets — Soluciones de Estanqueidad Industrial" description="Industrial Sealing Solutions desde 1985. Juntas, tornillería, corte y plegado. WMS inteligente con IA.">
  <div class="min-h-screen bg-gradient-to-b from-gray-950 via-gray-900 to-gray-950 text-slate-100">

    <header class="border-b border-slate-800/60 backdrop-blur-sm bg-gray-950/60">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/landing/" class="text-xl font-bold tracking-tight text-white">
          ESINSA <span class="text-indigo-400">Gaskets</span>
        </a>
        <nav class="hidden items-center gap-6 text-sm font-medium text-slate-400 md:flex">
          <a href="#stats" class="transition hover:text-white">Empresa</a>
          <a href="#productos" class="transition hover:text-white">Productos</a>
          <a href="#clientes" class="transition hover:text-white">Clientes</a>
        </nav>
        <a
          href={appUrl}
          class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-500"
          target="_blank"
          rel="noopener noreferrer"
        >
          Acceder al SGA
        </a>
      </div>
    </header>

    <main>
      <section class="mx-auto max-w-7xl px-6 py-24 text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          {home.sections.quality_service.title}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
          {home.sections.quality_service.description}
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a href={appUrl} class="rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-600/25 transition hover:bg-indigo-500" target="_blank" rel="noopener noreferrer">
            Acceder al Sistema SGA
          </a>
          <a href="#productos" class="rounded-lg border border-slate-700 px-6 py-3 text-sm font-semibold text-slate-300 transition hover:border-slate-500 hover:text-white">
            Conocer productos
          </a>
        </div>
      </section>

      <section id="stats" class="border-y border-slate-800/60 bg-slate-900/40">
        <div class="mx-auto grid max-w-7xl grid-cols-2 gap-px divide-slate-800/60 sm:grid-cols-3 lg:grid-cols-5">
          {empresa.content.stats.map((stat: { value: string; label: string }) => (
            <div class="flex flex-col items-center px-6 py-10 text-center">
              <span class="text-3xl font-extrabold text-indigo-400">{stat.value}</span>
              <span class="mt-2 text-sm text-slate-400">{stat.label}</span>
            </div>
          ))}
        </div>
      </section>

      <section id="productos" class="mx-auto max-w-7xl px-6 py-24">
        <h2 class="text-center text-3xl font-bold text-white">{home.sections.products_services.title}</h2>
        <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {home.sections.products_services.items.map((item: { name: string; description: string }) => (
            <div class="rounded-xl border border-slate-800/60 bg-slate-900/50 p-6 transition hover:border-indigo-600/40">
              <h3 class="text-lg font-semibold text-white">{item.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-400">{item.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="clientes" class="border-t border-slate-800/60 bg-slate-900/30 py-16">
        <div class="mx-auto max-w-7xl px-6">
          <p class="text-center text-sm font-medium uppercase tracking-widest text-slate-500">
            Confían en nosotros
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-8 opacity-60">
            {empresa.content.partners.map((partner: string) => (
              <span class="text-lg font-bold text-slate-300">{partner}</span>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-800/60 bg-gray-950 py-12">
      <div class="mx-auto max-w-7xl px-6 text-center text-sm text-slate-500">
        <p class="font-semibold text-slate-300">{company.legal_name}</p>
        <p class="mt-1">{company.address} — {company.zip} {company.city}, {company.province}</p>
        <p class="mt-1">
          <a href={`tel:${company.phone}`} class="hover:text-slate-300">{company.phone}</a>
          &nbsp;&middot;&nbsp;
          <a href={`mailto:${company.email}`} class="hover:text-slate-300">{company.email}</a>
        </p>
        <p class="mt-4 text-xs text-slate-600">
          &copy; {new Date().getFullYear()} {company.legal_name} — CIF {company.cif}
        </p>
      </div>
    </footer>

  </div>
</BaseLayout>
