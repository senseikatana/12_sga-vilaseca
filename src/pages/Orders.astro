---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import AutoCrud from '../components/AutoCrud';
import { useOrdersStore } from '../lib/stores';
---

<DashboardLayout title="Orders">
  <div slot="header-actions" class="flex gap-2 flex-wrap justify-end">
    <button
      id="btn-export-excel-orders"
      class="rounded-md bg-emerald-50 dark:bg-emerald-900/30 border border-emerald-200 dark:border-emerald-800 px-3 py-2 text-sm font-medium text-emerald-600 dark:text-emerald-400 transition hover:bg-emerald-100 dark:hover:bg-emerald-900/50 flex items-center gap-1 shadow-sm"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
      Excel
    </button>
    <input type="file" id="input-import-excel-orders" class="hidden" accept=".xlsx, .xls, .csv" />
    <button
      id="btn-import-excel-orders"
      class="rounded-md bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 px-3 py-2 text-sm font-medium text-blue-600 dark:text-blue-400 transition hover:bg-blue-100 dark:hover:bg-blue-900/50 flex items-center gap-1 shadow-sm"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
      Sync
    </button>
  </div>

  <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Orders vs monthly target" data-en="Orders vs monthly target" data-es="Pedidos vs objetivo mensual">Orders vs monthly target</h2>

      <div class="mt-4 h-64">
        <canvas
          id="orders-target-combo-chart"
          role="img"
          aria-label="Combo chart showing monthly orders against a target, with orders passing the target from April onward"
        ></canvas>
      </div>
    </div>

    <AutoCrud
      client:load
      type="orders"
      config={JSON.stringify({
        title: 'Todos los pedidos',
        description: 'Gestión de pedidos del almacén',
        columns: [
          { key: 'number', label: 'Pedido #', sortable: true },
          { key: 'customer', label: 'Cliente', sortable: true },
          { key: 'status', label: 'Estado', sortable: true },
          { key: 'amount', label: 'Importe', sortable: true },
        ],
        fields: [
          { name: 'customer', label: 'Cliente', type: 'text', placeholder: 'Nombre del cliente' },
          { name: 'status', label: 'Estado', type: 'select', options: [
            { value: 'paid', label: 'Pagado' },
            { value: 'pending', label: 'Pendiente' },
            { value: 'refunded', label: 'Reembolsado' },
          ]},
          { name: 'amount', label: 'Importe (€)', type: 'number' },
        ],
        searchKeys: ['number', 'customer'],
        idKey: 'id',
        displayKey: 'number',
      })}
    />

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
  import { useOrdersStore } from '../lib/stores';
  import { seedGenerators } from '../lib/stores';

  // Seed counters from any existing persisted data
  seedGenerators();

  // === ALBARAN AND SHIPPING LABEL LOGIC ===
  window.generateAlbaran = (id) => {
    const order = useOrdersStore.getState().items.find(o => o.id === id);
    if (!order) return;
    if (!window.jspdf) return alert('jsPDF no cargado.');
    const { jsPDF } = window.jspdf;

    // Albarán A4
    const doc = new jsPDF({ format: 'a4' });

    doc.setFont("helvetica", "bold");
    doc.setFontSize(22);
    doc.text("ALBARÁN DE ENTREGA", 105, 20, { align: 'center' });

    doc.setFontSize(12);
    doc.setFont("helvetica", "normal");
    doc.text("ESINSA GASKET", 20, 40);
    doc.text("Pol. Ind. Riu Clar, Tarragona", 20, 46);

    doc.setFont("helvetica", "bold");
    doc.text(`Cliente: ${order.customer}`, 120, 40);
    doc.text(`Nº Pedido: ${order.number}`, 120, 46);
    doc.text(`Fecha: ${new Date().toLocaleDateString()}`, 120, 52);

    doc.setLineWidth(0.5);
    doc.line(20, 60, 190, 60);

    doc.text("Descripción", 20, 70);
    doc.text("Cantidad", 120, 70);
    doc.text("Precio", 160, 70);

    doc.line(20, 72, 190, 72);

    doc.setFont("helvetica", "normal");
    doc.text("Materiales de Sellado y Juntas (Varios)", 20, 82);
    doc.text("1 Lote", 120, 82);
    doc.text(`$${order.amount}`, 160, 82);

    doc.line(20, 92, 190, 92);
    doc.setFont("helvetica", "bold");
    doc.text(`TOTAL: $${order.amount}`, 160, 102);

    doc.setFont("helvetica", "normal");
    doc.setFontSize(10);
    doc.text("Firma del receptor: _______________________", 20, 250);

    doc.save(`Albaran_${order.number}.pdf`);
  };

  window.generateShippingLabel = (id) => {
    const order = useOrdersStore.getState().items.find(o => o.id === id);
    if (!order) return;
    if (!window.jspdf) return alert('jsPDF no cargado.');
    const { jsPDF } = window.jspdf;

    // Etiqueta A6 Apaisada (Shipping label)
    const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a6' });

    doc.setLineWidth(1);
    doc.rect(5, 5, 138, 95);

    doc.setFontSize(24);
    doc.setFont("helvetica", "bold");
    doc.text("ETIQUETA DE ENVÍO", 74, 20, { align: 'center' });

    doc.setLineWidth(0.5);
    doc.line(10, 25, 138, 25);

    doc.setFontSize(14);
    doc.text("REMITENTE:", 10, 35);
    doc.setFont("helvetica", "normal");
    doc.text("ESINSA GASKET\nPol. Ind. Riu Clar\nTarragona, España", 10, 42);

    doc.setFont("helvetica", "bold");
    doc.text("DESTINATARIO:", 70, 35);
    doc.setFont("helvetica", "normal");
    doc.text(`${order.customer}\nDirección del cliente\nCiudad, País`, 70, 42);

    doc.line(10, 65, 138, 65);

    doc.setFont("courier", "normal");
    doc.setFontSize(22);
    doc.text(`*${order.number}*`, 74, 80, { align: 'center' });

    doc.setFont("helvetica", "normal");
    doc.setFontSize(10);
    doc.text(`Fecha: ${new Date().toLocaleDateString()}`, 10, 95);

    doc.save(`Envio_${order.number}.pdf`);
  };

  // === EXCEL SYNC LOGIC ===
  const btnExport = document.getElementById('btn-export-excel-orders');
  const btnImport = document.getElementById('btn-import-excel-orders');
  const fileImport = document.getElementById('input-import-excel-orders') as HTMLInputElement;

  btnExport.addEventListener('click', () => {
    if(!window.XLSX) return alert("SheetJS no está cargado.");
    const orders = useOrdersStore.getState().items;
    const ws = window.XLSX.utils.json_to_sheet(orders.map(o => ({
      ID_Pedido: o.number,
      Cliente: o.customer,
      Estado: o.status,
      Importe: o.amount
    })));
    const wb = window.XLSX.utils.book_new();
    window.XLSX.utils.book_append_sheet(wb, ws, "Pedidos CRM");
    window.XLSX.writeFile(wb, `Pedidos_${new Date().toISOString().split('T')[0]}.xlsx`);
  });

  btnImport.addEventListener('click', () => fileImport.click());

  fileImport.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (evt) => {
      try {
        if(!window.XLSX) return alert("SheetJS no está cargado.");
        const data = evt.target.result;
        const workbook = window.XLSX.read(data, { type: 'binary' });
        const ws = workbook.Sheets[workbook.SheetNames[0]];
        const json = window.XLSX.utils.sheet_to_json(ws);
        const store = useOrdersStore.getState();

        json.forEach((row: any) => {
          if (row.ID_Pedido) {
            store.addItem({
              customer: row.Cliente || 'Sin nombre',
              status: row.Estado || 'pending',
              amount: parseFloat(row.Importe) || 0
            });
          }
        });
        alert('Pedidos importados exitosamente.');
      } catch (err) {
        alert('Error importando el Excel.');
      }
      fileImport.value = '';
    };
    reader.readAsBinaryString(file);
  });

  // Chart setup
  const ordersTargetComboChartCanvas = document.getElementById('orders-target-combo-chart') as HTMLCanvasElement
  if (ordersTargetComboChartCanvas) {
    new Chart(ordersTargetComboChartCanvas, {
      type: 'bar',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [
          { type: 'bar', label: 'Orders', data: [210, 245, 228, 268, 289, 312], backgroundColor: '#4f46e5', borderRadius: 4, maxBarThickness: 32, order: 2 },
          { type: 'line', label: 'Target', data: [230, 230, 230, 260, 260, 260], borderColor: '#f59e0b', backgroundColor: '#f59e0b', borderWidth: 2, borderDash: [6, 4], pointRadius: 0, fill: false, order: 1 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: '#9ca3af' } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#9ca3af' } },
          y: { beginAtZero: true, grid: { color: '#374151' }, ticks: { color: '#9ca3af' } },
        },
      },
    })
  }
</script>

</DashboardLayout>
