---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignUp } from '@clerk/astro/components';
---

<BaseLayout title="Registro - ESINSA WMS">
  <div class="relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950">
    <div class="fixed inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80"
        alt=""
        class="h-full w-full object-cover opacity-20 dark:opacity-10"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-100/80 via-gray-100/90 to-gray-100/80 dark:from-gray-950/80 dark:via-gray-950/90 dark:to-gray-950/80"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-lg px-4 py-16 w-full">
      <div class="text-center">
        <div class="mx-auto inline-flex size-14 items-center justify-center rounded-full bg-indigo-600 shadow-lg shadow-indigo-600/25">
          <svg class="size-7 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
          </svg>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">ESINSA WMS</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Nuevo registro de operario</p>
      </div>

      <div class="mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl">
        <SignUp />
      </div>
    </div>
  </div>
</BaseLayout>
