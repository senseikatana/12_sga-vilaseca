---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="WhatsApp">
  <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 flex flex-col items-center justify-center text-center h-64">
    <svg class="size-12 text-green-500 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
    </svg>
    <h3 class="text-lg font-medium text-gray-900 dark:text-white" data-i18n="WhatsApp Agent" data-en="WhatsApp Agent" data-es="Agente WhatsApp">WhatsApp Agent</h3>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400" data-i18n="AI-driven CRM communication over WhatsApp." data-en="AI-driven CRM communication over WhatsApp." data-es="Comunicación CRM guiada por IA a través de WhatsApp.">AI-driven CRM communication over WhatsApp.</p>
  </div>
</DashboardLayout>
