---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="WhatsApp">
  <div class="space-y-6 max-w-5xl">

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <div class="flex items-start gap-4">
        <div class="flex size-14 shrink-0 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30">
          <svg class="size-7 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Agente WhatsApp JARVIS</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Asistente inteligente conectado a WhatsApp vía Baileys (gratis, sin API de Meta)</p>
          <div class="mt-3 flex items-center gap-3">
            <span id="wa-status" class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">
              <span class="size-1.5 rounded-full bg-red-500 animate-pulse"></span>
              Desconectado
            </span>
            <span class="text-xs text-gray-400 dark:text-gray-500">Puerto: 3008 | Cerebro: :4321/api/ai</span>
          </div>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">Para conectar, abre <a href="http://localhost:3008" target="_blank" class="text-indigo-600 dark:text-indigo-400 underline">localhost:3008</a> y escanea el QR desde WhatsApp &rarr; Dispositivos vinculados.</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
        <div class="flex size-10 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-900/30">
          <svg class="size-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
        </div>
        <h4 class="mt-3 font-semibold text-gray-900 dark:text-white text-sm">JARVIS IA</h4>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Gemini + FAQ industrial. Responde stock, pedidos, ubicaciones.</p>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
        <div class="flex size-10 items-center justify-center rounded-lg bg-green-100 dark:bg-green-900/30">
          <svg class="size-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" /></svg>
        </div>
        <h4 class="mt-3 font-semibold text-gray-900 dark:text-white text-sm">Multi-idioma</h4>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Español, Inglés y Catalán. Responde en el idioma del cliente.</p>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
        <div class="flex size-10 items-center justify-center rounded-lg bg-amber-100 dark:bg-amber-900/30">
          <svg class="size-5 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
        </div>
        <h4 class="mt-3 font-semibold text-gray-900 dark:text-white text-sm">Catálogo 5000+</h4>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Juntas, espárragos, tuercas, kits de brida. Búsqueda por NUT code.</p>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
        <div class="flex size-10 items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/30">
          <svg class="size-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h4 class="mt-3 font-semibold text-gray-900 dark:text-white text-sm">24/7 Disponible</h4>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Respuesta inmediata. Sin horarios. Parada de planta urgente atendida.</p>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h3 class="text-base font-semibold text-gray-900 dark:text-white">Probar JARVIS</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Envía una pregunta directamente al asistente</p>

      <div class="mt-4 flex gap-3">
        <input id="jarvis-input" type="text" placeholder="Ej: ¿Qué stock queda de la junta DN80?" class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-sm text-gray-900 dark:text-white shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
        <button id="jarvis-send" type="button" class="shrink-0 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition disabled:opacity-50">
          Enviar
        </button>
      </div>

      <div id="jarvis-response" class="hidden mt-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 p-4">
        <p class="text-xs font-medium text-gray-400 dark:text-gray-500 mb-1">JARVIS responde:</p>
        <p id="jarvis-response-text" class="text-sm text-gray-700 dark:text-gray-200 whitespace-pre-wrap"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 text-center">
        <p class="text-3xl font-bold text-gray-900 dark:text-white">0</p>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Mensajes hoy</p>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 text-center">
        <p class="text-3xl font-bold text-gray-900 dark:text-white">0</p>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Conversaciones activas</p>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 text-center">
        <p class="text-3xl font-bold text-green-600 dark:text-green-400">&lt;2s</p>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Tiempo medio de respuesta</p>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  const input = document.getElementById('jarvis-input') as HTMLInputElement;
  const sendBtn = document.getElementById('jarvis-send') as HTMLButtonElement;
  const responseDiv = document.getElementById('jarvis-response');
  const responseText = document.getElementById('jarvis-response-text');

  async function sendQuestion() {
    const question = input?.value.trim();
    if (!question) return;
    sendBtn.disabled = true;
    sendBtn.textContent = 'Consultando...';
    responseDiv?.classList.remove('hidden');
    if (responseText) responseText.textContent = 'Pensando...';

    try {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question, lang: 'es' }),
      });
      const data = await res.json();
      if (responseText) responseText.textContent = data?.reply || 'Sin respuesta';
    } catch {
      if (responseText) responseText.textContent = 'Error al conectar con JARVIS. Asegúrate de que el servidor esté corriendo.';
    }
    sendBtn.disabled = false;
    sendBtn.textContent = 'Enviar';
  }

  sendBtn?.addEventListener('click', sendQuestion);
  input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendQuestion(); });
</script>
