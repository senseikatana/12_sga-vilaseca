---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Picking">
  <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 flex flex-col items-center justify-center text-center h-64">
    <svg class="size-12 text-indigo-500 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
    </svg>
    <h3 class="text-lg font-medium text-gray-900 dark:text-white" data-i18n="AI Voice Picking" data-en="AI Voice Picking" data-es="Voice Picking con IA">AI Voice Picking</h3>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400" data-i18n="Hands-free warehouse picking module." data-en="Hands-free warehouse picking module." data-es="Módulo de picking de almacén manos libres.">Hands-free warehouse picking module.</p>
  </div>
</DashboardLayout>
