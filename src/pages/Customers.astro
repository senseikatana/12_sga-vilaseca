---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import AutoCrud from '../components/AutoCrud';
---

<DashboardLayout title="Customers">
  <div slot="header-actions" class="flex gap-2 flex-wrap justify-end">
    <button
      id="btn-export-excel-customers"
      class="rounded-md bg-emerald-50 dark:bg-emerald-900/30 border border-emerald-200 dark:border-emerald-800 px-3 py-2 text-sm font-medium text-emerald-600 dark:text-emerald-400 transition hover:bg-emerald-100 dark:hover:bg-emerald-900/50 flex items-center gap-1 shadow-sm"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
      Excel
    </button>
    <input type="file" id="input-import-excel-customers" class="hidden" accept=".xlsx, .xls, .csv" />
    <button
      id="btn-import-excel-customers"
      class="rounded-md bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 px-3 py-2 text-sm font-medium text-blue-600 dark:text-blue-400 transition hover:bg-blue-100 dark:hover:bg-blue-900/50 flex items-center gap-1 shadow-sm"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
      Sync
    </button>
  </div>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 lg:col-span-2">
        <h2 class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="New customers" data-en="New customers" data-es="Nuevos clientes">New customers</h2>

        <div class="mt-4 h-64">
          <canvas
            id="new-customers-bar-chart"
            role="img"
            aria-label="Bar chart showing new customers per month rising from 82 in January to 128 in June"
          ></canvas>
        </div>
      </div>

      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
        <h2 class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Customers by plan" data-en="Customers by plan" data-es="Clientes por plan">Customers by plan</h2>

        <ul class="mt-4 space-y-4">
          <li>
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium text-gray-900 dark:text-gray-300">Team</span>
              <span class="text-gray-600 dark:text-gray-400">1,406</span>
            </div>

            <div class="mt-1.5 h-1.5 rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-1.5 rounded-full bg-indigo-600" style="width: 61%"></div>
            </div>
          </li>

          <li>
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium text-gray-900 dark:text-gray-300">Starter</span>
              <span class="text-gray-600 dark:text-gray-400">742</span>
            </div>

            <div class="mt-1.5 h-1.5 rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-1.5 rounded-full bg-indigo-600" style="width: 32%"></div>
            </div>
          </li>

          <li>
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium text-gray-900 dark:text-gray-300">Enterprise</span>
              <span class="text-gray-600 dark:text-gray-400">170</span>
            </div>

            <div class="mt-1.5 h-1.5 rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-1.5 rounded-full bg-indigo-600" style="width: 7%"></div>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <AutoCrud
      client:load
      type="customers"
      config={JSON.stringify({
        title: 'Directorio de Clientes',
        description: 'Gestión de clientes y planes',
        columns: [
          { key: 'code', label: 'Código', sortable: true },
          { key: 'name', label: 'Nombre', sortable: true },
          { key: 'email', label: 'Email', sortable: true },
          { key: 'plan', label: 'Plan', sortable: true },
          { key: 'status', label: 'Estado', sortable: true },
        ],
        fields: [
          { name: 'name', label: 'Nombre completo', type: 'text', placeholder: 'Ej: Juan Pérez' },
          { name: 'email', label: 'Email', type: 'email', placeholder: 'cliente@esinsa.es' },
          { name: 'plan', label: 'Plan', type: 'select', options: [
            { value: 'Team', label: 'Team' },
            { value: 'Starter', label: 'Starter' },
            { value: 'Enterprise', label: 'Enterprise' },
          ]},
          { name: 'status', label: 'Estado', type: 'select', options: [
            { value: 'active', label: 'Activo' },
            { value: 'trial', label: 'Trial' },
            { value: 'past-due', label: 'Vencido' },
          ]},
        ],
        searchKeys: ['name', 'email', 'code'],
        idKey: 'id',
        displayKey: 'name',
      })}
    />

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
<script>
  import { useCustomersStore } from '../lib/stores';
  import { seedGenerators } from '../lib/stores';

  // Seed counters from any existing persisted data
  seedGenerators();

  // === EXCEL SYNC LOGIC ===
  const btnExport = document.getElementById('btn-export-excel-customers');
  const btnImport = document.getElementById('btn-import-excel-customers');
  const fileImport = document.getElementById('input-import-excel-customers') as HTMLInputElement;

  btnExport.addEventListener('click', () => {
    if(!window.XLSX) return alert("SheetJS no está cargado.");
    const customers = useCustomersStore.getState().items;
    const ws = window.XLSX.utils.json_to_sheet(customers.map(c => ({
      Nombre: c.name,
      Email: c.email,
      Plan: c.plan,
      Estado: c.status
    })));
    const wb = window.XLSX.utils.book_new();
    window.XLSX.utils.book_append_sheet(wb, ws, "Clientes CRM");
    window.XLSX.writeFile(wb, `Clientes_CRM_${new Date().toISOString().split('T')[0]}.xlsx`);
  });

  btnImport.addEventListener('click', () => fileImport.click());

  fileImport.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (evt) => {
      try {
        if(!window.XLSX) return alert("SheetJS no está cargado.");
        const data = evt.target.result;
        const workbook = window.XLSX.read(data, { type: 'binary' });
        const ws = workbook.Sheets[workbook.SheetNames[0]];
        const json = window.XLSX.utils.sheet_to_json(ws);
        const store = useCustomersStore.getState();

        json.forEach((row: any) => {
          if (row.Nombre || row.Email) {
            store.addItem({
              name: row.Nombre || 'Sin nombre',
              email: row.Email || 'Sin email',
              plan: row.Plan || 'Starter',
              status: row.Estado || 'active'
            });
          }
        });
        alert('Clientes importados exitosamente.');
      } catch (err) {
        alert('Error importando el Excel.');
      }
      fileImport.value = '';
    };
    reader.readAsBinaryString(file);
  });

  // Chart setup
  const newCustomersBarChartCanvas = document.getElementById('new-customers-bar-chart') as HTMLCanvasElement
  if (newCustomersBarChartCanvas) {
    new Chart(newCustomersBarChartCanvas, {
      type: 'bar',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
          label: 'New customers',
          data: [82, 95, 88, 110, 104, 128],
          backgroundColor: 'hsla(245, 76%, 58%, 1)',
          hoverBackgroundColor: 'hsla(245, 64%, 53%, 1)',
          borderRadius: 4,
          maxBarThickness: 32,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: 'hsla(220, 9%, 66%, 1)' } },
          y: { beginAtZero: true, grid: { color: 'hsla(217, 33%, 26%, 1)' }, ticks: { color: 'hsla(220, 9%, 66%, 1)' } },
        },
      },
    })
  }
</script>

</DashboardLayout>
