---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Iniciar Sesión - ESINSA WMS">
  <div id="auth-root"></div>
</BaseLayout>

<script>
  import React, { useState, useEffect, FormEvent } from 'react';
  import { createRoot } from 'react-dom/client';
  import { createClient } from '@insforge/sdk';

  const insforge = createClient({
    baseUrl: import.meta.env.PUBLIC_INSFORGE_URL,
    anonKey: import.meta.env.PUBLIC_INSFORGE_ANON_KEY,
  });

  function SignInForm() {
    const [email, setEmail] = useState('');
    const [password, setPassword] = useState('');
    const [error, setError] = useState('');
    const [loading, setLoading] = useState(false);
    const [checking, setChecking] = useState(true);

    useEffect(() => {
      (async () => {
        try {
          const { data } = await insforge.auth.getCurrentUser();
          if (data?.user) {
            window.location.href = '/';
            return;
          }
        } catch {}
        setChecking(false);
      })();
    }, []);

    const handleSubmit = async (e: FormEvent) => {
      e.preventDefault();
      setError('');
      setLoading(true);
      try {
        const { data, error: authError } = await insforge.auth.signInWithPassword({ email, password });
        if (authError) {
          if (authError.statusCode === 403) {
            setError('Email no verificado. Revisa tu bandeja de entrada.');
          } else {
            setError(authError.message || 'Credenciales incorrectas');
          }
          setLoading(false);
          return;
        }
        if (data?.accessToken) {
          window.location.href = '/';
        }
      } catch (e: any) {
        setError(e.message || 'Error al iniciar sesión');
        setLoading(false);
      }
    };

    const handleOAuth = async (provider: 'google' | 'github' | 'microsoft') => {
      await insforge.auth.signInWithOAuth(provider, {
        redirectTo: 'http://localhost:4321',
      });
    };

    if (checking) {
      return React.createElement('div', { className: 'flex min-h-screen items-center justify-center bg-gray-100 dark:bg-gray-950' },
        React.createElement('div', { className: 'text-center' },
          React.createElement('div', { className: 'mx-auto size-12 animate-spin rounded-full border-4 border-indigo-600 border-t-transparent' }),
          React.createElement('p', { className: 'mt-4 text-sm text-gray-500 dark:text-gray-400' }, 'Cargando...')
        )
      );
    }

    return React.createElement('div', { className: 'relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950' },
      React.createElement('div', { className: 'fixed inset-0 z-0' },
        React.createElement('img', { src: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80', alt: '', className: 'h-full w-full object-cover opacity-20 dark:opacity-10' }),
        React.createElement('div', { className: 'absolute inset-0 bg-gradient-to-b from-gray-100/80 via-gray-100/90 to-gray-100/80 dark:from-gray-950/80 dark:via-gray-950/90 dark:to-gray-950/80' })
      ),
      React.createElement('div', { className: 'relative z-10 mx-auto max-w-lg px-4 py-16 w-full' },
        React.createElement('div', { className: 'text-center' },
          React.createElement('div', { className: 'mx-auto inline-flex size-14 items-center justify-center rounded-full bg-indigo-600 shadow-lg shadow-indigo-600/25' },
            React.createElement('svg', { className: 'size-7 text-white', fill: 'none', viewBox: '0 0 24 24', strokeWidth: '1.5', stroke: 'currentColor' },
              React.createElement('path', { strokeLinecap: 'round', strokeLinejoin: 'round', d: 'M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z' })
            )
          ),
          React.createElement('h1', { className: 'mt-4 text-2xl font-bold text-gray-900 dark:text-white' }, 'ESINSA WMS'),
          React.createElement('p', { className: 'mt-1 text-sm text-gray-500 dark:text-gray-400' }, 'Sistema de Gestión de Almacenes')
        ),
        React.createElement('div', { className: 'mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl' },
          React.createElement('h2', { className: 'text-lg font-semibold text-gray-900 dark:text-white' }, 'Iniciar Sesión'),
          React.createElement('p', { className: 'mt-1 text-sm text-gray-500 dark:text-gray-400' }, 'Accede a tu cuenta de ESINSA'),

          error && React.createElement('div', { className: 'mt-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 text-sm text-red-700 dark:text-red-400' }, error),

          React.createElement('form', { onSubmit: handleSubmit, className: 'mt-6 space-y-4' },
            React.createElement('div', null,
              React.createElement('label', { className: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' }, 'Email'),
              React.createElement('input', {
                type: 'email', required: true, value: email,
                onChange: (e: any) => setEmail(e.target.value),
                className: 'w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none',
                placeholder: 'tu@email.com'
              })
            ),
            React.createElement('div', null,
              React.createElement('label', { className: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' }, 'Contraseña'),
              React.createElement('input', {
                type: 'password', required: true, value: password,
                onChange: (e: any) => setPassword(e.target.value),
                className: 'w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none',
                placeholder: '••••••••'
              })
            ),
            React.createElement('div', { className: 'flex items-center justify-end' },
              React.createElement('a', { href: '/ForgotPassword', className: 'text-sm text-indigo-600 hover:text-indigo-500 dark:text-indigo-400' }, '¿Olvidaste tu contraseña?')
            ),
            React.createElement('button', {
              type: 'submit', disabled: loading,
              className: 'w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed transition'
            }, loading ? 'Iniciando sesión...' : 'Iniciar Sesión')
          ),

          React.createElement('div', { className: 'relative my-6' },
            React.createElement('div', { className: 'absolute inset-0 flex items-center' },
              React.createElement('div', { className: 'w-full border-t border-gray-200 dark:border-gray-700' })
            ),
            React.createElement('div', { className: 'relative flex justify-center text-xs' },
              React.createElement('span', { className: 'bg-white px-2 text-gray-500 dark:bg-gray-900 dark:text-gray-400' }, 'O continúa con')
            )
          ),

          React.createElement('div', { className: 'grid grid-cols-3 gap-3' },
            React.createElement('button', {
              type: 'button', onClick: () => handleOAuth('google'),
              className: 'flex items-center justify-center gap-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition'
            },
              React.createElement('svg', { className: 'size-5', viewBox: '0 0 24 24' },
                React.createElement('path', { d: 'M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z', fill: '#4285F4' }),
                React.createElement('path', { d: 'M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z', fill: '#34A853' }),
                React.createElement('path', { d: 'M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z', fill: '#FBBC05' }),
                React.createElement('path', { d: 'M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z', fill: '#EA4335' })
              ),
              'Google'
            ),
            React.createElement('button', {
              type: 'button', onClick: () => handleOAuth('github'),
              className: 'flex items-center justify-center gap-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition'
            },
              React.createElement('svg', { className: 'size-5', fill: 'currentColor', viewBox: '0 0 24 24' },
                React.createElement('path', { d: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' })
              ),
              'GitHub'
            ),
            React.createElement('button', {
              type: 'button', onClick: () => handleOAuth('microsoft'),
              className: 'flex items-center justify-center gap-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition'
            },
              React.createElement('svg', { className: 'size-5', viewBox: '0 0 23 23' },
                React.createElement('path', { fill: '#f35325', d: 'M1 1h10v10H1z' }),
                React.createElement('path', { fill: '#81bc06', d: 'M12 1h10v10H12z' }),
                React.createElement('path', { fill: '#05a6f0', d: 'M1 12h10v10H1z' }),
                React.createElement('path', { fill: '#ffba08', d: 'M12 12h10v10H12z' })
              ),
              'Microsoft'
            )
          ),

          React.createElement('div', { className: 'relative my-6' },
            React.createElement('div', { className: 'absolute inset-0 flex items-center' },
              React.createElement('div', { className: 'w-full border-t border-gray-200 dark:border-gray-700' })
            ),
            React.createElement('div', { className: 'relative flex justify-center text-xs' },
              React.createElement('span', { className: 'bg-white px-2 text-gray-500 dark:bg-gray-900 dark:text-gray-400' }, '¿No tienes cuenta?')
            )
          ),
          React.createElement('a', { href: '/signup', className: 'block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-center text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700 transition' }, 'Crear nueva cuenta')
        )
      )
    );
  }

  const root = document.getElementById('auth-root');
  if (root) {
    createRoot(root).render(React.createElement(SignInForm));
  }
</script>
