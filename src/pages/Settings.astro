---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Configuración">
  <div class="space-y-6 max-w-3xl">

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Perfil</h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Información de tu cuenta</p>

      <div id="settings-avatar" class="mt-5 flex items-center gap-4">
        <img id="settings-avatar-img" src="" alt="Avatar" class="size-16 rounded-full object-cover ring-2 ring-gray-200 dark:ring-gray-700" />
        <div>
          <p id="settings-name-display" class="font-medium text-gray-900 dark:text-white"></p>
          <p id="settings-email-display" class="text-sm text-gray-500 dark:text-gray-400"></p>
          <span id="settings-role-badge" class="mt-1 inline-block rounded-full px-2 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400"></span>
        </div>
      </div>

      <form id="profile-form" class="mt-6 space-y-4">
        <div>
          <label for="profile-name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Nombre</label>
          <input type="text" id="profile-name" class="mt-1 block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-white shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="profile-email" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
          <input type="email" id="profile-email" readonly class="mt-1 block w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 px-3 py-2 text-sm text-gray-500 dark:text-gray-400 cursor-not-allowed" />
        </div>
        <div class="flex justify-end">
          <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">Guardar cambios</button>
        </div>
      </form>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Cambiar contraseña</h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Actualiza tu contraseña de acceso</p>

      <form id="password-form" class="mt-5 space-y-4">
        <div id="password-message" class="hidden rounded-lg px-4 py-3 text-sm"></div>
        <div>
          <label for="current-password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Contraseña actual</label>
          <input type="password" id="current-password" required class="mt-1 block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-white shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="new-password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Nueva contraseña</label>
          <input type="password" id="new-password" required minlength="6" class="mt-1 block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-white shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="confirm-password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Confirmar contraseña</label>
          <input type="password" id="confirm-password" required class="mt-1 block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-900 dark:text-white shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
        </div>
        <div class="flex justify-end">
          <button type="submit" class="rounded-lg bg-gray-900 dark:bg-gray-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2">Actualizar contraseña</button>
        </div>
      </form>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Apariencia</h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Personaliza el aspecto del sistema</p>

      <div class="mt-5 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Tema</label>
          <div class="flex gap-2">
            <button data-theme-btn="light" class="theme-select-btn flex-1 rounded-lg border-2 border-gray-300 dark:border-gray-600 bg-white px-4 py-3 text-sm font-medium text-gray-900 dark:text-white hover:border-indigo-500 transition">
              <svg class="mx-auto mb-1 size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
              Claro
            </button>
            <button data-theme-btn="dark" class="theme-select-btn flex-1 rounded-lg border-2 border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-3 text-sm font-medium text-gray-900 dark:text-white hover:border-indigo-500 transition">
              <svg class="mx-auto mb-1 size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
              Oscuro
            </button>
            <button data-theme-btn="system" class="theme-select-btn flex-1 rounded-lg border-2 border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-3 text-sm font-medium text-gray-900 dark:text-white hover:border-indigo-500 transition">
              <svg class="mx-auto mb-1 size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 7.41A2.25 2.25 0 012.25 5.495V5.25" /></svg>
              Sistema
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Notificaciones</h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gestiona tus preferencias de aviso</p>

      <ul class="mt-5 divide-y divide-gray-200 dark:divide-gray-800">
        <li class="flex items-center justify-between py-3">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Alertas de stock bajo</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Aviso cuando un producto esté por debajo del mínimo</p>
          </div>
          <label class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-gray-200 dark:bg-gray-700 transition has-checked:bg-indigo-600">
            <input type="checkbox" data-notif="low_stock" checked class="peer sr-only" />
            <span class="size-4 translate-x-1 rounded-full bg-white transition peer-checked:translate-x-6"></span>
          </label>
        </li>
        <li class="flex items-center justify-between py-3">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Actualizaciones de pedidos</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Notificar cambios de estado en pedidos</p>
          </div>
          <label class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-gray-200 dark:bg-gray-700 transition has-checked:bg-indigo-600">
            <input type="checkbox" data-notif="order_updates" checked class="peer sr-only" />
            <span class="size-4 translate-x-1 rounded-full bg-white transition peer-checked:translate-x-6"></span>
          </label>
        </li>
        <li class="flex items-center justify-between py-3">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Alertas WhatsApp</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Notificaciones de mensajes entrantes</p>
          </div>
          <label class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-gray-200 dark:bg-gray-700 transition has-checked:bg-indigo-600">
            <input type="checkbox" data-notif="whatsapp" class="peer sr-only" />
            <span class="size-4 translate-x-1 rounded-full bg-white transition peer-checked:translate-x-6"></span>
          </label>
        </li>
      </ul>
    </div>

    <div class="rounded-xl border border-red-200 dark:border-red-900/50 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Sesión</h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gestiona tu sesión activa</p>
      <div class="mt-5">
        <button id="logout-btn" type="button" class="rounded-lg border border-red-300 dark:border-red-800 px-4 py-2 text-sm font-medium text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition">
          Cerrar sesión
        </button>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { getCurrentSession, updatePassword, logoutUser } from '../lib/auth';

  const session = getCurrentSession();
  if (!session) { window.location.href = '/Login'; }

  const nameInput = document.getElementById('profile-name') as HTMLInputElement;
  const emailInput = document.getElementById('profile-email') as HTMLInputElement;
  const nameDisplay = document.getElementById('settings-name-display');
  const emailDisplay = document.getElementById('settings-email-display');
  const roleBadge = document.getElementById('settings-role-badge');
  const avatarImg = document.getElementById('settings-avatar-img') as HTMLImageElement;

  if (session) {
    nameInput.value = session.name;
    emailInput.value = session.email;
    if (nameDisplay) nameDisplay.textContent = session.name;
    if (emailDisplay) emailDisplay.textContent = session.email;
    if (roleBadge) roleBadge.textContent = session.role === 'admin' ? 'Administrador' : 'Operario';
    if (avatarImg) avatarImg.src = session.avatar || '';
  }

  document.getElementById('profile-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!session) return;
    const newName = nameInput.value.trim();
    if (!newName) return;
    const users = JSON.parse(localStorage.getItem('esinsa_wms_users') || '[]');
    const user = users.find((u: any) => u.id === session.userId);
    if (user) {
      user.name = newName;
      localStorage.setItem('esinsa_wms_users', JSON.stringify(users));
    }
    session.name = newName;
    sessionStorage.setItem('esinsa_wms_session', JSON.stringify(session));
    if (nameDisplay) nameDisplay.textContent = newName;
    const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]');
    if (btn) { btn.textContent = 'Guardado'; setTimeout(() => { btn.textContent = 'Guardar cambios'; }, 1500); }
  });

  document.getElementById('password-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const msgDiv = document.getElementById('password-message');
    const currentPw = (document.getElementById('current-password') as HTMLInputElement).value;
    const newPw = (document.getElementById('new-password') as HTMLInputElement).value;
    const confirmPw = (document.getElementById('confirm-password') as HTMLInputElement).value;

    if (!session || !msgDiv) return;
    if (newPw !== confirmPw) {
      msgDiv.textContent = 'Las contraseñas no coinciden';
      msgDiv.className = 'rounded-lg px-4 py-3 text-sm bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800';
      msgDiv.classList.remove('hidden');
      return;
    }
    const result = updatePassword(session.userId, newPw);
    if (result) {
      msgDiv.textContent = 'Contraseña actualizada correctamente';
      msgDiv.className = 'rounded-lg px-4 py-3 text-sm bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800';
      msgDiv.classList.remove('hidden');
      (e.target as HTMLFormElement).reset();
    } else {
      msgDiv.textContent = 'Error al actualizar contraseña';
      msgDiv.className = 'rounded-lg px-4 py-3 text-sm bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800';
      msgDiv.classList.remove('hidden');
    }
    setTimeout(() => msgDiv?.classList.add('hidden'), 4000);
  });

  const savedTheme = localStorage.getItem('theme') || 'light';
  document.querySelectorAll('[data-theme-btn]').forEach((btn) => {
    const theme = (btn as HTMLElement).dataset.themeBtn;
    if (theme === savedTheme) {
      btn.classList.add('border-indigo-500');
      btn.classList.remove('border-gray-300', 'dark:border-gray-600');
    }
    btn.addEventListener('click', () => {
      localStorage.setItem('theme', theme || 'light');
      const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.toggle('dark', isDark);
      document.querySelectorAll('[data-theme-btn]').forEach((b) => {
        b.classList.remove('border-indigo-500');
        b.classList.add('border-gray-300', 'dark:border-gray-600');
      });
      btn.classList.add('border-indigo-500');
      btn.classList.remove('border-gray-300', 'dark:border-gray-600');
    });
  });

  document.querySelectorAll('[data-notif]').forEach((toggle) => {
    const key = 'esinsa_wms_notif_' + (toggle as HTMLElement).dataset.notif;
    const saved = localStorage.getItem(key);
    (toggle as HTMLInputElement).checked = saved !== 'off';
    toggle.addEventListener('change', () => {
      localStorage.setItem(key, (toggle as HTMLInputElement).checked ? 'on' : 'off');
    });
  });

  document.getElementById('logout-btn')?.addEventListener('click', () => {
    if (confirm('¿Seguro que quieres cerrar sesión?')) {
      logoutUser();
      window.location.href = '/Login';
    }
  });
</script>
