---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Settings">
  <button slot="header-actions"
      type="submit"
      form="account-settings-form"
      class="rounded-md bg-gray-900 dark:bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-gray-800 dark:hover:bg-indigo-700"
      data-i18n="Save changes" data-en="Save changes" data-es="Guardar cambios"
    >
      Save changes
    </button>

  <form id="account-settings-form" class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Profile" data-en="Profile" data-es="Perfil">Profile</h2>

      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label for="full-name" class="block text-sm font-medium text-gray-700 dark:text-gray-300" data-i18n="Full name" data-en="Full name" data-es="Nombre completo">
            Full name
          </label>

          <input
            type="text"
            id="full-name"
            value="Priya Natarajan"
            class="mt-1 w-full rounded-md border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white shadow-xs"
          />
        </div>

        <div>
          <label for="email-address" class="block text-sm font-medium text-gray-700 dark:text-gray-300" data-i18n="Email address" data-en="Email address" data-es="Dirección de correo">
            Email address
          </label>

          <input
            type="email"
            id="email-address"
            value="priya@orbitly.com"
            class="mt-1 w-full rounded-md border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white shadow-xs"
          />
        </div>

        <div class="sm:col-span-2">
          <label for="team-name" class="block text-sm font-medium text-gray-700 dark:text-gray-300" data-i18n="Team name" data-en="Team name" data-es="Nombre del equipo">
            Team name
          </label>

          <input
            type="text"
            id="team-name"
            value="Orbitly"
            class="mt-1 w-full rounded-md border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white shadow-xs"
          />
        </div>
      </div>
    </form>

    <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Notifications" data-en="Notifications" data-es="Notificaciones">Notifications</h2>

      <ul class="mt-4 divide-y divide-gray-200 dark:divide-gray-800">
        <li class="flex items-center justify-between gap-4 py-3 first:pt-0 last:pb-0">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Email notifications" data-en="Email notifications" data-es="Notificaciones por correo">Email notifications</p>
            <p class="text-xs text-gray-600 dark:text-gray-400" data-i18n="Get notified when a customer places an order." data-en="Get notified when a customer places an order." data-es="Recibe un aviso cuando un cliente realiza un pedido.">Get notified when a customer places an order.</p>
          </div>

          <label
            for="email-notifications-toggle"
            class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-gray-200 dark:bg-gray-700 transition has-checked:bg-indigo-600 dark:has-checked:bg-indigo-500"
          >
            <input
              type="checkbox"
              id="email-notifications-toggle"
              checked
              class="peer sr-only"
            />

            <span
              class="size-4 translate-x-1 rounded-full bg-white transition peer-checked:translate-x-6"
            ></span>
          </label>
        </li>

        <li class="flex items-center justify-between gap-4 py-3 first:pt-0 last:pb-0">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Product updates" data-en="Product updates" data-es="Actualizaciones de producto">Product updates</p>
            <p class="text-xs text-gray-600 dark:text-gray-400" data-i18n="Occasional emails about new features." data-en="Occasional emails about new features." data-es="Correos ocasionales sobre nuevas funcionalidades.">Occasional emails about new features.</p>
          </div>

          <label
            for="product-updates-toggle"
            class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-gray-200 dark:bg-gray-700 transition has-checked:bg-indigo-600 dark:has-checked:bg-indigo-500"
          >
            <input type="checkbox" id="product-updates-toggle" class="peer sr-only" />

            <span
              class="size-4 translate-x-1 rounded-full bg-white transition peer-checked:translate-x-6"
            ></span>
          </label>
        </li>

        <li class="flex items-center justify-between gap-4 py-3 first:pt-0 last:pb-0">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Weekly summary" data-en="Weekly summary" data-es="Resumen semanal">Weekly summary</p>
            <p class="text-xs text-gray-600 dark:text-gray-400" data-i18n="A digest of revenue and orders every Monday." data-en="A digest of revenue and orders every Monday." data-es="Un resumen de ingresos y pedidos cada lunes.">A digest of revenue and orders every Monday.</p>
          </div>

          <label
            for="weekly-summary-toggle"
            class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer items-center rounded-full bg-gray-200 dark:bg-gray-700 transition has-checked:bg-indigo-600 dark:has-checked:bg-indigo-500"
          >
            <input
              type="checkbox"
              id="weekly-summary-toggle"
              checked
              class="peer sr-only"
            />

            <span
              class="size-4 translate-x-1 rounded-full bg-white transition peer-checked:translate-x-6"
            ></span>
          </label>
        </li>
      </ul>
    </div>

    <div class="rounded-lg border border-red-200 dark:border-red-900/50 bg-white dark:bg-gray-900 p-6">
      <h2 class="text-sm font-medium text-gray-900 dark:text-white" data-i18n="Danger zone" data-en="Danger zone" data-es="Zona de peligro">Danger zone</h2>

      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400" data-i18n="Deleting your team removes all customers, orders, and billing history. This cannot be undone." data-en="Deleting your team removes all customers, orders, and billing history. This cannot be undone." data-es="Al borrar tu equipo se eliminan todos los clientes, pedidos e historial. No se puede deshacer.">
        Deleting your team removes all customers, orders, and billing history. This cannot be undone.
      </p>

      <button
        type="button"
        class="mt-4 inline-block rounded-md border border-red-200 dark:border-red-800 px-4 py-2 text-sm font-medium text-red-700 dark:text-red-400 transition hover:bg-red-50 dark:hover:bg-red-900/30"
        data-i18n="Delete team" data-en="Delete team" data-es="Borrar equipo"
      >
        Delete team
      </button>
    </div>

</DashboardLayout>
