---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Recuperar Contraseña - ESINSA WMS">
  <div id="auth-root"></div>
</BaseLayout>

<script>
  import React, { useState, useEffect, FormEvent } from 'react';
  import { createRoot } from 'react-dom/client';
  import { createClient } from '@insforge/sdk';

  const insforge = createClient({
    baseUrl: import.meta.env.PUBLIC_INSFORGE_URL,
    anonKey: import.meta.env.PUBLIC_INSFORGE_ANON_KEY,
  });

  function ForgotPasswordForm() {
    const [step, setStep] = useState<'email' | 'code' | 'done'>('email');
    const [email, setEmail] = useState('');
    const [otp, setOtp] = useState('');
    const [newPassword, setNewPassword] = useState('');
    const [confirmPassword, setConfirmPassword] = useState('');
    const [error, setError] = useState('');
    const [loading, setLoading] = useState(false);

    const handleSendCode = async (e: FormEvent) => {
      e.preventDefault();
      setError('');
      setLoading(true);
      try {
        const { error: sendError } = await insforge.auth.sendResetPasswordEmail({
          email,
          redirectTo: 'http://localhost:4321/ForgotPassword',
        });
        if (sendError) {
          setError(sendError.message || 'Error al enviar el código');
          setLoading(false);
          return;
        }
        setStep('code');
      } catch (e: any) {
        setError(e.message || 'Error al enviar el código');
      }
      setLoading(false);
    };

    const handleResetPassword = async (e: FormEvent) => {
      e.preventDefault();
      setError('');

      if (newPassword !== confirmPassword) {
        setError('Las contraseñas no coinciden');
        return;
      }

      if (newPassword.length < 8) {
        setError('La contraseña debe tener al menos 8 caracteres');
        return;
      }

      setLoading(true);
      try {
        const { data: tokenData, error: exchangeError } = await insforge.auth.exchangeResetPasswordToken({
          email,
          code: otp,
        });

        if (exchangeError) {
          setError(exchangeError.message || 'Código inválido o expirado');
          setLoading(false);
          return;
        }

        const { error: resetError } = await insforge.auth.resetPassword({
          newPassword,
          otp: tokenData!.token,
        });

        if (resetError) {
          setError(resetError.message || 'Error al restablecer la contraseña');
          setLoading(false);
          return;
        }

        setStep('done');
      } catch (e: any) {
        setError(e.message || 'Error al restablecer la contraseña');
      }
      setLoading(false);
    };

    const bgImage = React.createElement('div', { className: 'fixed inset-0 z-0' },
      React.createElement('img', { src: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80', alt: '', className: 'h-full w-full object-cover opacity-20 dark:opacity-10' }),
      React.createElement('div', { className: 'absolute inset-0 bg-gradient-to-b from-gray-100/80 via-gray-100/90 to-gray-100/80 dark:from-gray-950/80 dark:via-gray-950/90 dark:to-gray-950/80' })
    );

    const header = React.createElement('div', { className: 'text-center' },
      React.createElement('div', { className: 'mx-auto inline-flex size-14 items-center justify-center rounded-full bg-indigo-600 shadow-lg shadow-indigo-600/25' },
        React.createElement('svg', { className: 'size-7 text-white', fill: 'none', viewBox: '0 0 24 24', strokeWidth: '1.5', stroke: 'currentColor' },
          React.createElement('path', { strokeLinecap: 'round', strokeLinejoin: 'round', d: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z' })
        )
      ),
      React.createElement('h1', { className: 'mt-4 text-2xl font-bold text-gray-900 dark:text-white' }, 'ESINSA WMS'),
      React.createElement('p', { className: 'mt-1 text-sm text-gray-500 dark:text-gray-400' }, 'Recuperación de contraseña')
    );

    if (step === 'done') {
      return React.createElement('div', { className: 'relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950' },
        bgImage,
        React.createElement('div', { className: 'relative z-10 mx-auto max-w-lg px-4 py-16 w-full' },
          header,
          React.createElement('div', { className: 'mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl text-center' },
            React.createElement('div', { className: 'mx-auto inline-flex size-16 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30' },
              React.createElement('svg', { className: 'size-8 text-green-600 dark:text-green-400', fill: 'none', viewBox: '0 0 24 24', strokeWidth: '1.5', stroke: 'currentColor' },
                React.createElement('path', { strokeLinecap: 'round', strokeLinejoin: 'round', d: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z' })
              )
            ),
            React.createElement('h2', { className: 'mt-4 text-lg font-semibold text-gray-900 dark:text-white' }, 'Contraseña actualizada'),
            React.createElement('p', { className: 'mt-2 text-sm text-gray-500 dark:text-gray-400' }, 'Tu contraseña ha sido restablecida correctamente.'),
            React.createElement('a', { href: '/signin', className: 'mt-6 inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition' }, 'Iniciar sesión')
          )
        )
      );
    }

    if (step === 'code') {
      return React.createElement('div', { className: 'relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950' },
        bgImage,
        React.createElement('div', { className: 'relative z-10 mx-auto max-w-lg px-4 py-16 w-full' },
          header,
          React.createElement('div', { className: 'mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl' },
            React.createElement('h2', { className: 'text-lg font-semibold text-gray-900 dark:text-white' }, 'Nueva contraseña'),
            React.createElement('p', { className: 'mt-1 text-sm text-gray-500 dark:text-gray-400' }, `Ingresa el código de 6 dígitos enviado a ${email} y tu nueva contraseña.`),

            error && React.createElement('div', { className: 'mt-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 text-sm text-red-700 dark:text-red-400' }, error),

            React.createElement('form', { onSubmit: handleResetPassword, className: 'mt-6 space-y-4' },
              React.createElement('div', null,
                React.createElement('label', { className: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' }, 'Código de recuperación'),
                React.createElement('input', {
                  type: 'text', required: true, value: otp, maxLength: 6,
                  onChange: (e: any) => setOtp(e.target.value.replace(/\D/g, '')),
                  className: 'w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-center text-gray-900 dark:text-white placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none text-lg tracking-[0.5em] font-mono',
                  placeholder: '000000'
                })
              ),
              React.createElement('div', null,
                React.createElement('label', { className: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' }, 'Nueva contraseña'),
                React.createElement('input', {
                  type: 'password', required: true, value: newPassword,
                  onChange: (e: any) => setNewPassword(e.target.value),
                  className: 'w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none',
                  placeholder: 'Mín. 8 caracteres'
                })
              ),
              React.createElement('div', null,
                React.createElement('label', { className: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' }, 'Confirmar contraseña'),
                React.createElement('input', {
                  type: 'password', required: true, value: confirmPassword,
                  onChange: (e: any) => setConfirmPassword(e.target.value),
                  className: 'w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none',
                  placeholder: '••••••••'
                })
              ),
              React.createElement('button', {
                type: 'submit', disabled: loading,
                className: 'w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed transition'
              }, loading ? 'Restableciendo...' : 'Restablecer contraseña')
            ),
            React.createElement('div', { className: 'mt-4 text-center' },
              React.createElement('button', {
                type: 'button', onClick: () => setStep('email'),
                className: 'text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300'
              }, '← Volver al paso anterior')
            )
          )
        )
      );
    }

    return React.createElement('div', { className: 'relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950' },
      bgImage,
      React.createElement('div', { className: 'relative z-10 mx-auto max-w-lg px-4 py-16 w-full' },
        header,
        React.createElement('div', { className: 'mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl' },
          React.createElement('h2', { className: 'text-lg font-semibold text-gray-900 dark:text-white' }, '¿Olvidaste tu contraseña?'),
          React.createElement('p', { className: 'mt-1 text-sm text-gray-500 dark:text-gray-400' }, 'Ingresa tu email y te enviaremos un código de recuperación.'),

          error && React.createElement('div', { className: 'mt-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 text-sm text-red-700 dark:text-red-400' }, error),

          React.createElement('form', { onSubmit: handleSendCode, className: 'mt-6 space-y-4' },
            React.createElement('div', null,
              React.createElement('label', { className: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' }, 'Email'),
              React.createElement('input', {
                type: 'email', required: true, value: email,
                onChange: (e: any) => setEmail(e.target.value),
                className: 'w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none',
                placeholder: 'admin@esinsa.es'
              })
            ),
            React.createElement('button', {
              type: 'submit', disabled: loading,
              className: 'w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed transition'
            }, loading ? 'Enviando...' : 'Enviar código')
          ),

          React.createElement('div', { className: 'relative my-6' },
            React.createElement('div', { className: 'absolute inset-0 flex items-center' },
              React.createElement('div', { className: 'w-full border-t border-gray-200 dark:border-gray-700' })
            ),
            React.createElement('div', { className: 'relative flex justify-center text-xs' },
              React.createElement('span', { className: 'bg-white px-2 text-gray-500 dark:bg-gray-900 dark:text-gray-400' }, '¿Recordaste tu contraseña?')
            )
          ),
          React.createElement('a', { href: '/signin', className: 'block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-center text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700 transition' }, 'Volver al inicio de sesión')
        )
      )
    );
  }

  const root = document.getElementById('auth-root');
  if (root) {
    createRoot(root).render(React.createElement(ForgotPasswordForm));
  }
</script>
