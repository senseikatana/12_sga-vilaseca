---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Recuperar Contraseña - ESINSA WMS">
  <div class="relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950">
    <div class="fixed inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80"
        alt=""
        class="h-full w-full object-cover opacity-20 dark:opacity-10"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-100/80 via-gray-100/90 to-gray-100/80 dark:from-gray-950/80 dark:via-gray-950/90 dark:to-gray-950/80"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-lg px-4 py-16 w-full">
      <div class="text-center">
        <div class="mx-auto inline-flex size-14 items-center justify-center rounded-full bg-indigo-600 shadow-lg shadow-indigo-600/25">
          <svg class="size-7 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">ESINSA WMS</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Recuperación de contraseña</p>
      </div>

      <div class="mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl">

        <div id="step-email">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">¿Olvidaste tu contraseña?</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Ingresa tu email y te enviaremos un código de recuperación.</p>

          <div id="reset-error" class="hidden items-center gap-2 rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 px-4 py-3 mt-4 text-sm text-red-700 dark:text-red-400">
            <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <span id="reset-error-text"></span>
          </div>

          <form id="email-form" class="mt-6 space-y-5">
            <label for="reset-email" class="block">
              <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Email</span>
              <input
                type="email"
                id="reset-email"
                required
                autocomplete="email"
                placeholder="admin@esinsa.es"
                class="mt-0.5 block w-full rounded-lg border border-gray-300 shadow-sm sm:text-sm dark:border-gray-600 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500"
              />
            </label>

            <button
              type="submit"
              id="email-submit"
              class="flex w-full items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 dark:focus:ring-offset-gray-900"
            >
              <span id="email-submit-text">Enviar código</span>
              <svg id="email-submit-spinner" class="hidden size-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
              </svg>
            </button>
          </form>
        </div>

        <div id="step-sent" class="hidden text-center py-4">
          <div class="mx-auto inline-flex size-16 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30">
            <svg class="size-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h2 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">Código enviado</h2>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Hemos enviado un código de recuperación a <span id="sent-email" class="font-medium text-gray-700 dark:text-gray-300"></span>.
            Revisa tu bandeja de entrada.
          </p>
          <div id="demo-token-box" class="mt-4 rounded-lg border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 px-4 py-3 text-sm text-amber-700 dark:text-amber-400">
            <p class="font-medium">Demo: tu código de recuperación es</p>
            <p id="demo-token" class="mt-1 font-mono text-lg font-bold break-all"></p>
          </div>
          <button
            id="go-reset-btn"
            class="mt-6 flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
          >
            Restablecer contraseña
          </button>
        </div>

        <div id="step-reset" class="hidden">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Nueva contraseña</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Ingresa el código recibido y tu nueva contraseña.</p>

          <div id="reset2-error" class="hidden items-center gap-2 rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 px-4 py-3 mt-4 text-sm text-red-700 dark:text-red-400">
            <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <span id="reset2-error-text"></span>
          </div>

          <form id="reset-form" class="mt-6 space-y-4">
            <label for="reset-token" class="block">
              <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Código de recuperación</span>
              <input
                type="text"
                id="reset-token"
                required
                placeholder="Pega el código aquí"
                class="mt-0.5 block w-full rounded-lg border border-gray-300 shadow-sm sm:text-sm dark:border-gray-600 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500 font-mono"
              />
            </label>

            <label for="new-password" class="block">
              <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Nueva contraseña</span>
              <input
                type="password"
                id="new-password"
                required
                autocomplete="new-password"
                placeholder="Mínimo 6 caracteres"
                class="mt-0.5 block w-full rounded-lg border border-gray-300 shadow-sm sm:text-sm dark:border-gray-600 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500"
              />
            </label>

            <label for="confirm-password" class="block">
              <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Confirmar contraseña</span>
              <input
                type="password"
                id="confirm-password"
                required
                autocomplete="new-password"
                placeholder="Repite la contraseña"
                class="mt-0.5 block w-full rounded-lg border border-gray-300 shadow-sm sm:text-sm dark:border-gray-600 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500"
              />
            </label>

            <button
              type="submit"
              id="reset-submit"
              class="flex w-full items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 dark:focus:ring-offset-gray-900"
            >
              <span id="reset-submit-text">Restablecer contraseña</span>
              <svg id="reset-submit-spinner" class="hidden size-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
              </svg>
            </button>
          </form>
        </div>

        <div id="step-done" class="hidden text-center py-4">
          <div class="mx-auto inline-flex size-16 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30">
            <svg class="size-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">Contraseña actualizada</h2>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Tu contraseña ha sido restablecida correctamente.</p>
          <a
            href="/Login"
            class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
          >
            Iniciar sesión
          </a>
        </div>

        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200 dark:border-gray-700"></div>
          </div>
          <div class="relative flex justify-center text-xs">
            <span class="bg-white/90 dark:bg-gray-900/90 px-2 text-gray-500 dark:text-gray-400">¿Recordaste tu contraseña?</span>
          </div>
        </div>

        <a
          href="/Login"
          class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-center text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          Volver al inicio de sesión
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { requestPasswordReset, resetPassword } from '../lib/auth';

  const stepEmail = document.getElementById('step-email');
  const stepSent = document.getElementById('step-sent');
  const stepReset = document.getElementById('step-reset');
  const stepDone = document.getElementById('step-done');

  const emailForm = document.getElementById('email-form');
  const emailInput = document.getElementById('reset-email');
  const emailSubmit = document.getElementById('email-submit');
  const emailSubmitText = document.getElementById('email-submit-text');
  const emailSubmitSpinner = document.getElementById('email-submit-spinner');
  const resetError = document.getElementById('reset-error');
  const resetErrorText = document.getElementById('reset-error-text');
  const sentEmail = document.getElementById('sent-email');
  const demoToken = document.getElementById('demo-token');
  const goResetBtn = document.getElementById('go-reset-btn');

  const resetForm = document.getElementById('reset-form');
  const tokenInput = document.getElementById('reset-token');
  const newPasswordInput = document.getElementById('new-password');
  const confirmPasswordInput = document.getElementById('confirm-password');
  const resetSubmit = document.getElementById('reset-submit');
  const resetSubmitText = document.getElementById('reset-submit-text');
  const resetSubmitSpinner = document.getElementById('reset-submit-spinner');
  const reset2Error = document.getElementById('reset2-error');
  const reset2ErrorText = document.getElementById('reset2-error-text');

  let currentToken = '';

  function showStep(step: 'email' | 'sent' | 'reset' | 'done') {
    [stepEmail, stepSent, stepReset, stepDone].forEach(el => el?.classList.add('hidden'));
    if (step === 'email') stepEmail?.classList.remove('hidden');
    if (step === 'sent') stepSent?.classList.remove('hidden');
    if (step === 'reset') stepReset?.classList.remove('hidden');
    if (step === 'done') stepDone?.classList.remove('hidden');
  }

  emailForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    resetError?.classList.add('hidden');

    const email = emailInput.value.trim();
    if (!email) return;

    emailSubmit.disabled = true;
    emailSubmitText.textContent = 'Enviando...';
    emailSubmitSpinner?.classList.remove('hidden');

    setTimeout(() => {
      const result = requestPasswordReset(email);

      emailSubmit.disabled = false;
      emailSubmitText.textContent = 'Enviar código';
      emailSubmitSpinner?.classList.add('hidden');

      if (result.success && result.token) {
        currentToken = result.token;
        sentEmail.textContent = email;
        demoToken.textContent = result.token;
        showStep('sent');
      } else {
        resetErrorText.textContent = result.error || 'Error al enviar el código';
        resetError?.classList.remove('hidden');
        resetError?.classList.add('flex');
      }
    }, 600);
  });

  goResetBtn?.addEventListener('click', () => {
    tokenInput.value = currentToken;
    showStep('reset');
  });

  resetForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    reset2Error?.classList.add('hidden');

    const token = tokenInput.value.trim();
    const newPass = newPasswordInput.value;
    const confirmPass = confirmPasswordInput.value;

    if (newPass !== confirmPass) {
      reset2ErrorText.textContent = 'Las contraseñas no coinciden';
      reset2Error?.classList.remove('hidden');
      reset2Error?.classList.add('flex');
      return;
    }

    resetSubmit.disabled = true;
    resetSubmitText.textContent = 'Restableciendo...';
    resetSubmitSpinner?.classList.remove('hidden');

    setTimeout(() => {
      const result = resetPassword(token, newPass);

      resetSubmit.disabled = false;
      resetSubmitText.textContent = 'Restablecer contraseña';
      resetSubmitSpinner?.classList.add('hidden');

      if (result.success) {
        showStep('done');
      } else {
        reset2ErrorText.textContent = result.error || 'Error al restablecer la contraseña';
        reset2Error?.classList.remove('hidden');
        reset2Error?.classList.add('flex');
      }
    }, 600);
  });
</script>
