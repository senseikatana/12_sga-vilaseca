---
// src/pages/index.astro
import dynamicData from '../data/esinsa-dynamic-full.json';

const homeData = dynamicData.home;
const sectoresData = dynamicData.sectores;
---

<Layout>
  <section class="bg-white dark:bg-gray-900">
    <div class="py-8 px-4 mx-auto max-w-screen-xl">
      <!-- Renderiza el texto dinámico sin etiquetas HTML peligrosas -->
      <h1 class="text-3xl font-bold">{homeData.title}</h1>
      <p class="text-gray-600">{homeData.text.substring(0, 200)}</p>
      
      <!-- Si quieres mostrar el HTML enriquecido (con estilos), usa set:html -->
      <div class="prose" set:html={sectoresData.html} />
      
      <!-- Mostrar imágenes capturadas -->
      <div class="grid grid-cols-3 gap-4">
        {homeData.images.slice(0, 3).map((img) => (
          <img src={img.src} alt={img.alt} class="rounded-lg" />
        ))}
      </div>
    </div>
  </section>
</Layout>