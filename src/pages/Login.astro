---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignIn } from '@clerk/astro/components';
---

<BaseLayout title="Iniciar Sesión - ESINSA WMS">
  <div class="relative min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-950">
    <div class="fixed inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80"
        alt=""
        class="h-full w-full object-cover opacity-20 dark:opacity-10"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-100/80 via-gray-100/90 to-gray-100/80 dark:from-gray-950/80 dark:via-gray-950/90 dark:to-gray-950/80"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-lg px-4 py-16 w-full">
      <div class="text-center">
        <div class="mx-auto inline-flex size-14 items-center justify-center rounded-full bg-indigo-600 shadow-lg shadow-indigo-600/25">
          <svg class="size-7 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z" />
          </svg>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">ESINSA WMS</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Sistema de Gestión de Almacenes</p>
      </div>

      <div class="mt-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm p-8 shadow-xl">
        <SignIn />
      </div>

      <p class="mt-6 text-center text-xs text-gray-400 dark:text-gray-500">
        ESINSA Gaskets · Demo: admin@esinsa.es / admin123
      </p>
    </div>
  </div>
</BaseLayout>
