---
import UserMenu from './UserMenu';

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "");

const navItems = [
  { name: 'Overview', es: 'Panel General', href: '/', current: currentPath === '' || currentPath === '/' },
  { name: 'Inventory', es: 'Inventario y Stock', href: '/Inventory', current: currentPath === '/Inventory' },
  { name: 'Customers', es: 'Clientes', href: '/Customers', current: currentPath === '/Customers' },
  { name: 'Orders', es: 'Pedidos', href: '/Orders', current: currentPath === '/Orders' },
  { name: 'Picking', es: 'Picking con IA', href: '/Picking', current: currentPath === '/Picking' },
  { name: 'WhatsApp', es: 'Agente WhatsApp', href: '/WhatsApp', current: currentPath === '/WhatsApp' },
  { name: 'Settings', es: 'Ajustes', href: '/Settings', current: currentPath === '/Settings' },
];
---

<div
  id="dashboard-sidebar"
  class="fixed inset-y-0 start-0 z-40 flex w-64 -translate-x-full flex-col justify-between overflow-y-auto border-e border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 transition-transform duration-300 peer-checked:translate-x-0 lg:static lg:translate-x-0 lg:shrink-0"
>
  <div class="p-4">
    <a href="/" class="grid h-12 w-32 place-content-center rounded-lg bg-gray-100 dark:bg-gray-800 text-sm font-bold text-indigo-600 dark:text-indigo-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
      ESINSA WMS
    </a>

    <nav aria-label="Dashboard" class="mt-4">
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              data-i18n={item.name}
              data-en={item.name}
              data-es={item.es}
              class={`block rounded-lg px-4 py-2 text-sm font-medium ${
                item.current
                  ? 'bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white'
                  : 'text-gray-600 dark:text-gray-400 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'
              }`}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="sticky inset-x-0 bottom-0 border-t border-gray-200 dark:border-gray-800">
    <div
      id="sidebar-user-profile"
      class="flex items-center gap-2 bg-white dark:bg-gray-900 p-4"
    >
      <img
        id="sidebar-user-avatar"
        alt="User Avatar"
        src="https://images.unsplash.com/photo-1600486913747-55e5470d6f40?auto=format&fit=crop&q=80&w=1160"
        class="size-10 rounded-full object-cover border border-gray-200 dark:border-gray-700"
      />
      <div class="flex-1 min-w-0">
        <p class="text-xs text-gray-900 dark:text-white">
          <strong id="sidebar-user-name" class="block font-medium truncate">Cargando...</strong>
          <span id="sidebar-user-email" class="text-gray-500 dark:text-gray-400 truncate block">...</span>
        </p>
      </div>
      <button
        id="sidebar-logout-btn"
        title="Cerrar sesión"
        class="shrink-0 rounded-md p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
      >
        <svg class="size-4" fill="none" viewBox="0 0 24 24" strokeWidth="1.5" stroke="currentColor">
          <path strokeLinecap="round" strokeLinejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    function updateSidebarUser() {
      try {
        const raw = sessionStorage.getItem('esinsa_wms_session');
        if (!raw) {
          window.location.href = '/Login';
          return;
        }
        const session = JSON.parse(raw);
        
        const nameEl = document.getElementById('sidebar-user-name');
        const emailEl = document.getElementById('sidebar-user-email');
        const avatarEl = document.getElementById('sidebar-user-avatar');
        
        if (nameEl) nameEl.textContent = session.name;
        if (emailEl) emailEl.textContent = session.email;
        if (avatarEl && session.avatar) avatarEl.src = session.avatar;
      } catch(e) {
        console.error('Auth error:', e);
      }
    }

    document.addEventListener('DOMContentLoaded', updateSidebarUser);

    // Logout handler
    document.getElementById('sidebar-logout-btn')?.addEventListener('click', function() {
      sessionStorage.removeItem('esinsa_wms_session');
      window.location.href = '/Login';
    });
  })();
</script>
