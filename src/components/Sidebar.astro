---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "");

const navItems = [
  { name: 'Overview', es: 'Panel General', href: '/', current: currentPath === '' || currentPath === '/' },
  { name: 'Inventory', es: 'Inventario y Stock', href: '/Inventory', current: currentPath === '/Inventory' },
  { name: 'Customers', es: 'Clientes', href: '/Customers', current: currentPath === '/Customers' },
  { name: 'Orders', es: 'Pedidos', href: '/Orders', current: currentPath === '/Orders' },
  { name: 'Picking', es: 'Picking con IA', href: '/Picking', current: currentPath === '/Picking' },
  { name: 'WhatsApp', es: 'Agente WhatsApp', href: '/WhatsApp', current: currentPath === '/WhatsApp' },
  { name: 'Settings', es: 'Ajustes', href: '/Settings', current: currentPath === '/Settings' },
];
---

<div
  id="dashboard-sidebar"
  class="fixed inset-y-0 start-0 z-40 flex w-64 -translate-x-full flex-col justify-between overflow-y-auto border-e border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 transition-transform duration-300 peer-checked:translate-x-0 lg:static lg:translate-x-0 lg:shrink-0"
>
  <div class="p-4">
    <span
      class="grid h-12 w-32 place-content-center rounded-lg bg-gray-100 dark:bg-gray-800 text-sm font-bold text-indigo-600 dark:text-indigo-400"
    >
      WarehouseFlow
    </span>

    <nav aria-label="Dashboard" class="mt-4">
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              data-i18n={item.name}
              data-en={item.name}
              data-es={item.es}
              class={`block rounded-lg px-4 py-2 text-sm font-medium ${
                item.current
                  ? 'bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white'
                  : 'text-gray-600 dark:text-gray-400 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'
              }`}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="sticky inset-x-0 bottom-0 border-t border-gray-200 dark:border-gray-800">
    <a
      href="#"
      class="flex items-center gap-2 bg-white dark:bg-gray-900 p-4 hover:bg-gray-50 dark:hover:bg-gray-800 hover:transition-colors"
    >
      <img
        alt="User Avatar"
        src="https://images.unsplash.com/photo-1600486913747-55e5470d6f40?auto=format&fit=crop&q=80&w=1160"
        class="size-10 rounded-full object-cover border border-gray-200 dark:border-gray-700"
      />

      <p class="text-xs text-gray-900 dark:text-white">
        <strong class="block font-medium">Administrador</strong>
        <span class="text-gray-500 dark:text-gray-400">admin@warehouseflow.com</span>
      </p>
    </a>
  </div>
</div>
