---
// Jarvis AI Assistant - Asistente digital inteligente para ESINSA WMS
// Analiza inventario, pedidos y clientes en tiempo real
---

<div id="jarvis-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
  <!-- Chat Window -->
  <div
    id="jarvis-chat-window"
    class="hidden w-96 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-2xl mb-4 overflow-hidden flex flex-col h-[32rem] transition-all duration-300 ease-out"
  >
    <!-- Header -->
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 p-4 flex justify-between items-center text-white">
      <div class="flex items-center gap-3">
        <div class="relative">
          <div class="size-10 rounded-full bg-white/20 flex items-center justify-center">
            <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
            </svg>
          </div>
          <span class="absolute bottom-0 right-0 size-3 bg-emerald-400 rounded-full border-2 border-white animate-pulse"></span>
        </div>
        <div>
          <h3 class="font-bold text-lg">JARVIS</h3>
          <p class="text-xs text-indigo-100" id="jarvis-status">Analizando datos...</p>
        </div>
      </div>
      <div class="flex items-center gap-1">
        <button id="jarvis-refresh" class="p-2 hover:bg-white/20 rounded-lg transition-colors" title="Actualizar análisis">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </button>
        <button id="jarvis-close" class="p-2 hover:bg-white/20 rounded-lg transition-colors">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Quick Stats -->
    <div id="jarvis-stats" class="grid grid-cols-3 gap-2 p-3 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-800">
      <div class="text-center p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
        <p class="text-xs text-gray-500 dark:text-gray-400">Productos</p>
        <p class="text-lg font-bold text-indigo-600 dark:text-indigo-400" id="stat-products">0</p>
      </div>
      <div class="text-center p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
        <p class="text-xs text-gray-500 dark:text-gray-400">Stock Bajo</p>
        <p class="text-lg font-bold text-red-500" id="stat-low-stock">0</p>
      </div>
      <div class="text-center p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
        <p class="text-xs text-gray-500 dark:text-gray-400">Pedidos</p>
        <p class="text-lg font-bold text-emerald-600 dark:text-emerald-400" id="stat-orders">0</p>
      </div>
    </div>

    <!-- Messages -->
    <div id="jarvis-messages" class="flex-1 p-4 overflow-y-auto space-y-4 bg-gray-50 dark:bg-gray-900">
      <!-- Welcome Message -->
      <div class="flex gap-3">
        <div class="size-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shrink-0">
          <svg class="size-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
          </svg>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl rounded-tl-none p-3 shadow-sm border border-gray-200 dark:border-gray-700 max-w-[85%]">
          <p class="text-sm text-gray-700 dark:text-gray-300">
            ¡Hola! Soy <strong>JARVIS</strong>, tu asistente de almacén. Tengo acceso completo al inventario, pedidos y clientes. 
            Puedo ayudarte con análisis, búsquedas y recomendaciones.
          </p>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="p-3 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
      <div class="flex flex-wrap gap-2 mb-3">
        <button class="jarvis-quick-action text-xs px-3 py-1.5 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 hover:bg-indigo-200 dark:hover:bg-indigo-900/50 transition-colors" data-query="stock bajo">
          📉 Stock bajo
        </button>
        <button class="jarvis-quick-action text-xs px-3 py-1.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 hover:bg-emerald-200 dark:hover:bg-emerald-900/50 transition-colors" data-query="ubicaciones">
          📍 Ubicaciones
        </button>
        <button class="jarvis-quick-action text-xs px-3 py-1.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 hover:bg-amber-200 dark:hover:bg-amber-900/50 transition-colors" data-query="pedidos pendientes">
          📦 Pedidos pendientes
        </button>
        <button class="jarvis-quick-action text-xs px-3 py-1.5 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 hover:bg-purple-200 dark:hover:bg-purple-900/50 transition-colors" data-query="resumen">
          📊 Resumen
        </button>
      </div>
      
      <!-- Input -->
      <div class="flex gap-2">
        <input
          type="text"
          id="jarvis-input"
          placeholder="Pregunta sobre inventario, pedidos..."
          class="flex-1 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-500 focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all"
        />
        <button
          id="jarvis-send"
          class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white p-2.5 rounded-xl transition-all shadow-md hover:shadow-lg"
        >
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Toggle Button -->
  <button
    id="jarvis-toggle"
    class="group relative bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white p-4 rounded-full shadow-xl transition-all duration-300 hover:scale-110 flex items-center justify-center"
  >
    <span class="absolute -top-1 -right-1 size-4 bg-emerald-400 rounded-full border-2 border-white animate-ping"></span>
    <span class="absolute -top-1 -right-1 size-4 bg-emerald-400 rounded-full border-2 border-white"></span>
    <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
    </svg>
  </button>
</div>

<script>
  import { useInventoryStore, useOrdersStore, useCustomersStore } from '../lib/stores';

  // ============================================================
  // JARVIS AI ASSISTANT - Análisis inteligente de almacén
  // ============================================================

  interface JarvisContext {
    inventory: any[];
    orders: any[];
    customers: any[];
    lowStockItems: any[];
    pendingOrders: any[];
    locations: Map<string, any[]>;
  }

  class JarvisAssistant {
    private container: HTMLElement | null = null;
    private chatWindow: HTMLElement | null = null;
    private messagesContainer: HTMLElement | null = null;
    private input: HTMLInputElement | null = null;
    private isOpen = false;
    private context: JarvisContext | null = null;

    constructor() {
      this.init();
    }

    private init() {
      this.container = document.getElementById('jarvis-container');
      this.chatWindow = document.getElementById('jarvis-chat-window');
      this.messagesContainer = document.getElementById('jarvis-messages');
      this.input = document.getElementById('jarvis-input') as HTMLInputElement;

      this.setupEventListeners();
      this.updateContext();
      this.startRealtimeSync();
    }

    private setupEventListeners() {
      // Toggle button
      document.getElementById('jarvis-toggle')?.addEventListener('click', () => this.toggle());
      document.getElementById('jarvis-close')?.addEventListener('click', () => this.close());
      document.getElementById('jarvis-refresh')?.addEventListener('click', () => this.refresh());

      // Send message
      document.getElementById('jarvis-send')?.addEventListener('click', () => this.sendMessage());
      this.input?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') this.sendMessage();
      });

      // Quick actions
      document.querySelectorAll('.jarvis-quick-action').forEach(btn => {
        btn.addEventListener('click', () => {
          const query = btn.getAttribute('data-query');
          if (query) {
            this.input!.value = query;
            this.sendMessage();
          }
        });
      });

      // Close on escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isOpen) this.close();
      });
    }

    private updateContext() {
      const inventory = useInventoryStore.getState().items;
      const orders = useOrdersStore.getState().items;
      const customers = useCustomersStore.getState().items;

      // Calculate low stock items (threshold: 100)
      const lowStockItems = inventory.filter(item => item.stock < 100);

      // Get pending orders
      const pendingOrders = orders.filter(o => o.status === 'pending');

      // Group by location
      const locations = new Map<string, any[]>();
      inventory.forEach(item => {
        const loc = item.loc || 'Sin ubicación';
        if (!locations.has(loc)) {
          locations.set(loc, []);
        }
        locations.get(loc)!.push(item);
      });

      this.context = {
        inventory,
        orders,
        customers,
        lowStockItems,
        pendingOrders,
        locations
      };

      this.updateStats();
    }

    private updateStats() {
      if (!this.context) return;

      const statProducts = document.getElementById('stat-products');
      const statLowStock = document.getElementById('stat-low-stock');
      const statOrders = document.getElementById('stat-orders');
      const status = document.getElementById('jarvis-status');

      if (statProducts) statProducts.textContent = this.context.inventory.length.toString();
      if (statLowStock) statLowStock.textContent = this.context.lowStockItems.length.toString();
      if (statOrders) statOrders.textContent = this.context.orders.length.toString();
      if (status) status.textContent = `Sincronizado • ${this.context.inventory.length} productos`;
    }

    private startRealtimeSync() {
      // Subscribe to store changes
      useInventoryStore.subscribe(() => { this.updateContext(); this.schedulePushToServer(); });
      useOrdersStore.subscribe(() => { this.updateContext(); this.schedulePushToServer(); });
      useCustomersStore.subscribe(() => { this.updateContext(); this.schedulePushToServer(); });

      // Auto-refresh every 30 seconds + sync al servidor cada 5 min
      setInterval(() => this.updateContext(), 30000);
      setInterval(() => this.pushDataToServer(), 5 * 60 * 1000);

      // Primera sincronización al cargar
      this.pushDataToServer();
    }

    // ============================================================
    // Sincronización navegador → servidor (para JARVIS 24/7 y WhatsApp)
    // ============================================================
    private pushTimer: ReturnType<typeof setTimeout> | null = null;

    private schedulePushToServer() {
      if (this.pushTimer) clearTimeout(this.pushTimer);
      this.pushTimer = setTimeout(() => this.pushDataToServer(), 3000);
    }

    private async pushDataToServer() {
      if (!this.context) return;
      try {
        await fetch('/api/sync-data', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            inventory: this.context.inventory,
            orders: this.context.orders,
            customers: this.context.customers,
          }),
        });
      } catch {
        // Servidor no disponible (modo estático); JARVIS sigue funcionando local
      }
    }

    // ============================================================
    // Pregunta al servidor (LLM OpenRouter) con fallback local
    // ============================================================
    private async askServer(question: string): Promise<string | null> {
      try {
        const lang = localStorage.getItem('lang') || 'es';
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 15000);
        const res = await fetch('/api/ai', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          signal: controller.signal,
          body: JSON.stringify({
            question,
            lang,
            data: {
              inventory: this.context?.inventory ?? [],
              orders: this.context?.orders ?? [],
              customers: this.context?.customers ?? [],
            },
          }),
        });
        clearTimeout(timeout);
        if (!res.ok) return null;
        const json = await res.json();
        return json?.reply ?? null;
      } catch {
        return null;
      }
    }

    private toggle() {
      if (this.isOpen) {
        this.close();
      } else {
        this.open();
      }
    }

    private open() {
      this.chatWindow?.classList.remove('hidden');
      this.isOpen = true;
      this.input?.focus();
      this.updateContext();
    }

    private close() {
      this.chatWindow?.classList.add('hidden');
      this.isOpen = false;
    }

    private refresh() {
      this.updateContext();
      this.addMessage('Datos actualizados. Tengo la información más reciente del almacén.', false);
    }

    private addMessage(text: string, isUser: boolean) {
      if (!this.messagesContainer) return;

      const messageDiv = document.createElement('div');
      messageDiv.className = `flex gap-3 ${isUser ? 'flex-row-reverse' : ''}`;

      const avatar = document.createElement('div');
      avatar.className = `size-8 rounded-full flex items-center justify-center shrink-0 ${
        isUser 
          ? 'bg-gray-200 dark:bg-gray-700' 
          : 'bg-gradient-to-br from-indigo-500 to-purple-600'
      }`;
      
      if (isUser) {
        avatar.innerHTML = `<svg class="size-4 text-gray-600 dark:text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`;
      } else {
        avatar.innerHTML = `<svg class="size-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`;
      }

      const content = document.createElement('div');
      content.className = `rounded-2xl p-3 shadow-sm border max-w-[85%] ${
        isUser
          ? 'bg-indigo-600 text-white rounded-tr-none border-indigo-600'
          : 'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 rounded-tl-none'
      }`;

      const paragraph = document.createElement('p');
      paragraph.className = `text-sm ${isUser ? 'text-white' : 'text-gray-700 dark:text-gray-300'}`;
      paragraph.innerHTML = text;

      content.appendChild(paragraph);
      messageDiv.appendChild(avatar);
      messageDiv.appendChild(content);

      this.messagesContainer.appendChild(messageDiv);
      this.messagesContainer.scrollTop = this.messagesContainer.scrollHeight;
    }

    private async sendMessage() {
      const text = this.input?.value.trim();
      if (!text) return;

      this.addMessage(text, true);
      this.input!.value = '';

      // Show typing indicator
      this.showTyping();

      // 1º intento: servidor (LLM con contexto completo). Fallback: reglas locales.
      const serverReply = await this.askServer(text);
      this.hideTyping();
      const response = serverReply ?? this.processQuery(text);
      this.addMessage(response, false);
    }

    private showTyping() {
      if (!this.messagesContainer) return;
      
      const typingDiv = document.createElement('div');
      typingDiv.id = 'jarvis-typing';
      typingDiv.className = 'flex gap-3';
      typingDiv.innerHTML = `
        <div class="size-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shrink-0">
          <svg class="size-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09l2.846.813-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
          </svg>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl rounded-tl-none p-3 shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="flex gap-1">
            <span class="size-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
            <span class="size-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
            <span class="size-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
          </div>
        </div>
      `;
      this.messagesContainer.appendChild(typingDiv);
      this.messagesContainer.scrollTop = this.messagesContainer.scrollHeight;
    }

    private hideTyping() {
      document.getElementById('jarvis-typing')?.remove();
    }

    private processQuery(query: string): string {
      if (!this.context) return 'Cargando datos...';

      const q = query.toLowerCase();

      // Stock bajo
      if (q.includes('stock bajo') || q.includes('bajo stock') || q.includes('sin stock')) {
        const items = this.context.lowStockItems;
        if (items.length === 0) {
          return '✅ <strong>Excelente noticia:</strong> No hay productos con stock bajo. Todos los niveles están por encima del umbral de 100 unidades.';
        }
        
        let response = `⚠️ <strong>Alerta de Stock Bajo:</strong> He encontrado ${items.length} producto(s) con menos de 100 unidades:<br><br>`;
        items.slice(0, 5).forEach(item => {
          response += `• <strong>${item.nutcode}</strong> - ${item.desc}<br>&nbsp;&nbsp;Stock: <span class="text-red-500 font-bold">${item.stock}</span> uds | Ubicación: ${item.loc}<br>`;
        });
        if (items.length > 5) {
          response += `<br>... y ${items.length - 5} más. ¿Quieres que genere un reporte completo?`;
        }
        return response;
      }

      // Ubicaciones
      if (q.includes('ubicación') || q.includes('ubicaciones') || q.includes('donde está')) {
        const locs = Array.from(this.context.locations.entries());
        if (locs.length === 0) {
          return '📍 No hay ubicaciones registradas en el sistema.';
        }
        
        let response = `📍 <strong>Mapa de Ubicaciones:</strong> Tengo registradas ${locs.length} ubicaciones activas:<br><br>`;
        locs.slice(0, 6).forEach(([loc, items]) => {
          const totalStock = items.reduce((sum, i) => sum + i.stock, 0);
          response += `• <strong>${loc}</strong>: ${items.length} referencias (${totalStock} uds totales)<br>`;
        });
        if (locs.length > 6) {
          response += `<br>... y ${locs.length - 6} ubicaciones más.`;
        }
        return response;
      }

      // Pedidos pendientes
      if (q.includes('pedido') || q.includes('pendiente') || q.includes('orden')) {
        const pending = this.context.pendingOrders;
        if (pending.length === 0) {
          return '✅ <strong>Todo al día:</strong> No hay pedidos pendientes de procesar.';
        }
        
        let response = `📦 <strong>Pedidos Pendientes:</strong> Hay ${pending.length} pedido(s) esperando procesamiento:<br><br>`;
        pending.slice(0, 5).forEach(order => {
          response += `• <strong>${order.number}</strong> - ${order.customer}<br>&nbsp;&nbsp;Importe: €${order.amount.toFixed(2)}<br>`;
        });
        return response;
      }

      // Resumen general
      if (q.includes('resumen') || q.includes('estado') || q.includes('general') || q.includes('analiza')) {
        const inv = this.context.inventory;
        const totalStock = inv.reduce((sum, i) => sum + i.stock, 0);
        const avgStock = inv.length > 0 ? Math.round(totalStock / inv.length) : 0;
        const categories = [...new Set(inv.map(i => i.type))];
        
        return `📊 <strong>Resumen Ejecutivo del Almacén:</strong><br><br>
          • <strong>Inventario total:</strong> ${inv.length} referencias únicas<br>
          • <strong>Stock acumulado:</strong> ${totalStock.toLocaleString()} unidades<br>
          • <strong>Stock promedio:</strong> ${avgStock} uds/referencia<br>
          • <strong>Categorías:</strong> ${categories.join(', ')}<br>
          • <strong>Alertas de stock:</strong> ${this.context.lowStockItems.length} productos<br>
          • <strong>Pedidos activos:</strong> ${this.context.orders.length} (${this.context.pendingOrders.length} pendientes)<br>
          • <strong>Clientes registrados:</strong> ${this.context.customers.length}<br><br>
          <em>¿Necesitas profundizar en algún área específica?</em>`;
      }

      // Búsqueda por NUTCODE
      if (q.includes('nut') || q.match(/nut\d+/i)) {
        const match = q.match(/nut\d+/i);
        if (match) {
          const item = this.context.inventory.find(i => i.nutcode.toLowerCase() === match[0].toLowerCase());
          if (item) {
            const status = item.stock < 100 ? '<span class="text-red-500">⚠️ STOCK BAJO</span>' : '<span class="text-emerald-500">✅ STOCK OK</span>';
            return `🔍 <strong>Producto Encontrado:</strong><br><br>
              • <strong>NUTCODE:</strong> ${item.nutcode}<br>
              • <strong>Descripción:</strong> ${item.desc}<br>
              • <strong>Tipo:</strong> ${item.type}<br>
              • <strong>Stock:</strong> ${item.stock} unidades ${status}<br>
              • <strong>Ubicación:</strong> ${item.loc}<br><br>
              ${item.stock < 50 ? '⚠️ <strong>Recomendación:</strong> Programar reposición urgente.' : ''}`;
          } else {
            return `❌ No he encontrado el producto con código <strong>${match[0]}</strong>. ¿Podrías verificar el código?`;
          }
        }
      }

      // Clientes
      if (q.includes('cliente') || q.includes('customer')) {
        const active = this.context.customers.filter(c => c.status === 'active');
        return `👥 <strong>Base de Clientes:</strong><br><br>
          • Total registrados: ${this.context.customers.length}<br>
          • Activos: ${active.length}<br>
          • En trial: ${this.context.customers.filter(c => c.status === 'trial').length}<br>
          • Con pagos pendientes: ${this.context.customers.filter(c => c.status === 'past-due').length}<br><br>
          ¿Necesitas contactar con algún cliente específico?`;
      }

      // Ayuda / Default
      return `🤖 <strong>JARVIS a tu servicio.</strong> Puedo ayudarte con:<br><br>
        • <strong>"stock bajo"</strong> - Ver productos con inventario crítico<br>
        • <strong>"ubicaciones"</strong> - Mapa de ubicaciones del almacén<br>
        • <strong>"pedidos pendientes"</strong> - Pedidos por procesar<br>
        • <strong>"resumen"</strong> - Análisis ejecutivo completo<br>
        • <strong>"NUT0001"</strong> - Buscar producto por código<br>
        • <strong>"clientes"</strong> - Estado de la cartera de clientes<br><br>
        <em>Estoy sincronizado en tiempo real con Excel/Sheet. ¿Qué necesitas?</em>`;
    }
  }

  // Initialize Jarvis when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new JarvisAssistant());
  } else {
    new JarvisAssistant();
  }
</script>
